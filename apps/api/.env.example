# Kopiuj do apps/api/.env i uzupełnij. .env NIGDY nie trafia do repo.
# Walidacja tych zmiennych: apps/api/src/config/env.ts

# --- Serwer ---
NODE_ENV=development
PORT=3000

# --- Baza danych (wymagane od BE-3) ---
# Lokalnie: Postgres z docker-compose (FND-3). Prod: Neon (FND-4).
DATABASE_URL="postgresql://trzycele:trzycele@localhost:5432/trzycele?schema=public"

# --- Better Auth (wymagane od BE-4) ---
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
