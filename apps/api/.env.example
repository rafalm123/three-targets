# Kopiuj do apps/api/.env i uzupełnij. .env NIGDY nie trafia do repo.
# Walidacja tych zmiennych: apps/api/src/config/env.ts

# --- Serwer ---
NODE_ENV=development
PORT=3000

# --- Baza danych (DATABASE_URL wymagane od BE-3) ---
# Lokalnie (docker-compose/Colima): DIRECT_URL = ta sama wartość co DATABASE_URL.
# Prod (Neon): DATABASE_URL = pooled (PgBouncer), DIRECT_URL = direct (non-pooled, pod migracje Prisma).
DATABASE_URL="postgresql://trzycele:trzycele@localhost:5432/trzycele"
DIRECT_URL="postgresql://trzycele:trzycele@localhost:5432/trzycele"

# --- Better Auth (wymagane od BE-4) ---
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
