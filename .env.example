# Kopiuj do .env i uzupełnij. .env NIGDY nie trafia do repo.

# --- Baza danych ---
# Lokalnie: Postgres z docker-compose (patrz FND-3). Prod: Neon (patrz FND-4).
DATABASE_URL="postgresql://trzycele:trzycele@localhost:5432/trzycele?schema=public"

# --- Better Auth (uzupełniane przy BE-4) ---
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# --- Serwer ---
PORT=3000
NODE_ENV=development
